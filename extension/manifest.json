{
  "manifest_version": 3,
  "name": "MeetBot — AI Meeting Notes",
  "version": "1.0.0",
  "description": "Automatically records, transcribes, and summarises your Zoom, Google Meet, and Teams calls.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MeetBot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/meet.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "tabs",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.recall.ai/*"
  ],
  "externally_connectable": {
    "matches": ["https://*.vercel.app/*", "http://localhost:3000/*", "http://localhost:3100/*"]
  },
  "oauth2": {
    "client_id": "__GOOGLE_CLIENT_ID__",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  }
}
